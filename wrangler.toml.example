# Copy this to wrangler.toml and fill in the real IDs.
# Run these to create resources:
#   wrangler d1 create core-db
#   wrangler kv:namespace create core-sessions
#   wrangler r2 bucket create core-media
# Then paste the returned IDs below.

name = "core"
compatibility_date = "2024-11-01"
compatibility_flags = ["nodejs_compat"]
pages_build_output_dir = "./build/client"

[[d1_databases]]
binding = "DB"
database_name = "core-db"
database_id = "REPLACE_WITH_D1_DATABASE_ID"

[[kv_namespaces]]
binding = "KV"
id = "REPLACE_WITH_KV_NAMESPACE_ID"

[[r2_buckets]]
binding = "R2"
bucket_name = "core-media"

[vars]
COMMUNITY_CREATION_OPEN = "false"
